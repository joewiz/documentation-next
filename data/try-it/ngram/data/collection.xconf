<collection xmlns="http://exist-db.org/collection-config/1.0">
    <!--
        Index configuration for try-it sample data (ngram module).
        Deployed by finish.xq into /db/system/config/.../try-it/ngram/data/
    -->
    <index>
        <ngram qname="name"/>
        <ngram qname="city"/>
        <ngram qname="email"/>
        <ngram qname="description"/>
    </index>
</collection>
